# Quarter Roadmap Co-Pilot — environment variables.
# Copy to `.env` and fill in. NEVER commit the real `.env` (it's git-ignored).
#
# Authentication: pick ONE of the two options below.

# --- Option 1: Gemini API key (Google AI Studio) — simplest, recommended for the demo ---
# Get a key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GOOGLE_GENAI_USE_ENTERPRISE=FALSE

# --- Option 2: Google Cloud Application Default Credentials (for Vertex AI / Agent Runtime) ---
# Run: gcloud auth application-default login
# GOOGLE_GENAI_USE_ENTERPRISE=TRUE
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-west1

# --- Agent Runtime deploy target (codelab 10). Filled in after `agents-cli deploy`. ---
AGENT_RUNTIME_ID=

# --- FastAPI dashboard (codelab 09 pattern). Port the cockpit listens on. ---
DASHBOARD_PORT=8080
